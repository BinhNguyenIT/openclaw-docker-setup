# Example second OpenClaw instance on the same host
COMPOSE_PROJECT_NAME=openclaw2
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.8
OPENCLAW_GATEWAY_CONTAINER_NAME=openclaw2-gateway
OPENCLAW_CLI_CONTAINER_NAME=openclaw2-cli
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18790
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CONFIG_DIR=./data2/config
OPENCLAW_WORKSPACE_DIR=./data2/workspace
TZ=UTC

CLI_PROXY_IMAGE=eceasy/cli-proxy-api:v6.8.51
CLI_PROXY_CONTAINER_NAME=openclaw2-cli-proxy-api
CLI_PROXY_CONFIG_PATH=./data2/cli-proxy-api/config.yaml
CLI_PROXY_AUTH_PATH=./data2/cli-proxy-api/auths
CLI_PROXY_LOG_PATH=./data2/cli-proxy-api/logs
CLI_PROXY_API_PORT=8318
CLI_PROXY_MANAGEMENT_PORT=8086
CLI_PROXY_PORT_1455=2455
CLI_PROXY_PORT_54545=54546
CLI_PROXY_PORT_51121=51122
CLI_PROXY_PORT_11451=11452
DEPLOY=
