# Example second OpenClaw instance on the same host
# This second instance shares the same CLIProxyAPI service as instance 1.
COMPOSE_PROJECT_NAME=openclaw2
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.23-2
OPENCLAW_GATEWAY_CONTAINER_NAME=openclaw2-gateway
OPENCLAW_CLI_CONTAINER_NAME=openclaw2-cli
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18790
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ROOT_DIR=./mounts/openclaw2/root
OPENCLAW_CONFIG_DIR=./mounts/openclaw2/config
OPENCLAW_CACHE_DIR=./mounts/openclaw2/cache
TZ=UTC
