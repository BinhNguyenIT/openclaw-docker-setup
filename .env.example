# Copy thành .env rồi chỉnh nếu cần
COMPOSE_PROJECT_NAME=openclaw
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.8
OPENCLAW_GATEWAY_CONTAINER_NAME=openclaw-gateway
OPENCLAW_CLI_CONTAINER_NAME=openclaw-cli
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CONFIG_DIR=./data/config
OPENCLAW_WORKSPACE_DIR=./data/workspace
TZ=UTC

CLI_PROXY_IMAGE=eceasy/cli-proxy-api:v6.8.51
CLI_PROXY_CONTAINER_NAME=cli-proxy-api
CLI_PROXY_CONFIG_PATH=./data/cli-proxy-api/config.yaml
CLI_PROXY_AUTH_PATH=./data/cli-proxy-api/auths
CLI_PROXY_LOG_PATH=./data/cli-proxy-api/logs
CLI_PROXY_API_PORT=8317
CLI_PROXY_MANAGEMENT_PORT=8085
CLI_PROXY_PORT_1455=1455
CLI_PROXY_PORT_54545=54545
CLI_PROXY_PORT_51121=51121
CLI_PROXY_PORT_11451=11451
DEPLOY=
